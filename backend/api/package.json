{
  "name": "jyotishconnect-api",
  "version": "1.0.0",
  "description": "JyotishConnect backend API",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --forceExit --ci",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:e2e:ui": "playwright test --config=playwright.config.js --headed",
    "test:e2e:flutter": "playwright test --config=playwright.config.js tests/e2e/flutter_ui.spec.js",
    "serve:flutter": "npx serve -p 8282 ../apps/mobile/build/web",
    "lint": "eslint ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "agora-access-token": "^2.0.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "pg": "^8.20.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/e2e/"
    ]
  }
}
