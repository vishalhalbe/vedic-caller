{
  "name": "jyotishconnect-api",
  "version": "1.0.0",
  "description": "JyotishConnect backend API",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "test": "jest",
    "test:ci": "jest --forceExit --ci",
    "test:e2e": "playwright test --config=playwright.config.js",
    "test:e2e:ui": "playwright test --config=playwright.config.js --headed",
    "test:e2e:flutter": "playwright test --config=playwright.config.js tests/e2e/flutter_ui.spec.js",
    "serve:flutter": "npx serve -p 8282 ../apps/mobile/build/web",
    "lint": "eslint ."
  },
  "dependencies": {
    "agora-access-token": "^2.0.4",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "razorpay": "^2.9.2",
    "sequelize": "^6.35.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
