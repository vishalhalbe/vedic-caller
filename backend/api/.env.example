# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development      # Set to "production" before deploy

# ── Database ─────────────────────────────────────────────────
DB_URI=postgres://user:password@localhost:5432/jyotish

# ── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret_min_48_chars

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Agora ─────────────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ── Redis (optional — idempotency store) ──────────────────────
# Leave blank to use in-memory fallback (dev only)
REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave empty for mobile-only)
ALLOWED_ORIGINS=
