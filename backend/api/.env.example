# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development      # Set to "production" before deploy

# ── Database — Supabase (required) ───────────────────────────
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_publishable_key

# Direct connection URI (optional — used by migrations / psql)
DB_URI=postgres://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_strong_random_secret_min_48_chars

# ── Razorpay ─────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Agora ─────────────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate

# ── App Config ────────────────────────────────────────────────
# Comma-separated origins allowed by CORS (include your Flutter web URL)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8282

# ── Cleanup cron ─────────────────────────────────────────────
CLEANUP_SECRET=replace_with_strong_random_secret

# ── Admin bootstrap ──────────────────────────────────────────
# Used once: POST /admin/seed { email, password } with x-seed-secret header
ADMIN_SEED_SECRET=replace_with_strong_random_secret

# ── MCP Credentials (dev machine only, never in CI/CD) ────────
# Base64-encoded Razorpay API key for MCP server in .mcp.json
# Generate: echo -n "rzp_live_KEY:SECRET" | base64
RAZORPAY_MCP_TOKEN=your_base64_encoded_razorpay_key_secret
